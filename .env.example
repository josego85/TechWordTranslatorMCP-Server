# TechWordTranslator API Configuration
# Example: http://localhost:8000 or https://your-api-domain.com
TECHWORD_TRANSLATOR_API_URL=http://localhost:8000

# MCP Server Configuration (optional)
MCP_SERVER_NAME=TechWord Translator
MCP_SERVER_VERSION=0.3.0

# Sanctum service token for write operations (create/update/delete words & translations).
# Generate via: POST /api/v1/service-tokens  (requires a valid JWT login first)
# Leave empty for read-only mode.
TECHWORD_API_TOKEN=
